/* pages/submit/submit.wxss */
.container {
  padding-bottom: 140rpx;
}

.job-card {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  color: #fff;
}

.job-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.job-position {
  font-size: 36rpx;
  font-weight: 600;
}

.job-salary {
  font-size: 30rpx;
  color: #fff7e6;
  font-weight: 500;
}

.job-company {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  opacity: 0.9;
}

.job-info {
  display: flex;
  gap: 12rpx;
}

.info-tag {
  font-size: 24rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.form-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 30rpx;
  color: #666;
}

.label.required::before {
  content: '* ';
  color: #ff4d4f;
}

.form-item input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.picker-value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #999;
}

.intro-textarea {
  width: 100%;
  height: 240rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.file-upload {
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: #999;
}

.file-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5f5f5;
  padding: 24rpx;
  border-radius: 12rpx;
}

.file-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.file-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.file-detail {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.file-size {
  font-size: 24rpx;
  color: #999;
}

.file-delete {
  width: 48rpx;
  height: 48rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.tips {
  margin: 0 20rpx 40rpx;
  padding: 0 20rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.bottom-placeholder {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.submit-btn {
  background: #1890ff;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}
